{
  "entities": {
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback, suggestions or comments from users",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the feedback"
        },
        "name": {
          "type": "string",
          "description": "Optional name of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Optional email of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the feedback was submitted"
        }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedbacks"
    }
  }
}
